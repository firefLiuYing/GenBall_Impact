    {
      "id": "file:Assets/Scripts/Yueyn/Main/SystemScope.cs",
      "type": "file",
      "name": "SystemScope.cs",
      "filePath": "Assets/Scripts/Yueyn/Main/SystemScope.cs",
      "summary": "定义系统更新范围枚举，区分 Game（游戏业务系统）和 Framework（框架基建系统），用于 SystemUpdater 决定将系统放入哪个更新队列。",
      "tags": ["enum-definition", "framework", "system-lifecycle"],
      "complexity": "simple"
    },
    {
      "id": "file:Assets/Scripts/Yueyn/Main/SystemUpdater.cs",
      "type": "file",
      "name": "SystemUpdater.cs",
      "filePath": "Assets/Scripts/Yueyn/Main/SystemUpdater.cs",
      "summary": "核心系统更新调度器，维护 Framework 和 Game 两组队列（Logic/Frame/LateFrame），负责系统的注册、注销和批量驱动更新。",
      "tags": ["framework", "update-loop", "scheduler", "system-lifecycle"],
      "complexity": "moderate",
      "languageNotes": "使用 SafeIterableList 确保遍历时安全增删；区分 Game 与 Framework 两组队列支持独立暂停控制。"
    },
    {
      "id": "file:Assets/Scripts/Yueyn/Main/SystemUpdaterManager.cs",
      "type": "file",
      "name": "SystemUpdaterManager.cs",
      "filePath": "Assets/Scripts/Yueyn/Main/SystemUpdaterManager.cs",
      "summary": "系统更新管理器，持有两个 SystemUpdater 实例分别管理 Game 和 Framework 系统，根据 ISystem 的 SystemScope 自动路由注册，支持暂停和恢复。",
      "tags": ["framework", "update-loop", "scheduler", "pause-control"],
      "complexity": "moderate"
    },
    {
      "id": "file:Assets/Scripts/Yueyn/ObjectPool/IObjectPool.cs",
